# Copy to .env.local (gitignored) and fill in. All optional — the server runs without any of these,
# falling back to stdout for notifications.

# --- Daily digest delivery (daily.ts) ---
# macOS iMessage: your phone number or Apple ID. If set, the daily digest texts you via Messages.app
# (needs Messages signed in + a one-time Automation permission grant).
AFY_IMESSAGE_TO=

# URL the daily text links to. localhost only opens on the Mac itself; set to the Mac's LAN IP
# (e.g. http://192.168.1.42:2727) to tap it from your phone on the same wifi.
AFY_CLIENT_URL=http://localhost:2727
AFY_SERVER_URL=http://localhost:2727
AFY_DAILY_DAYS=2

# --- Flush notifier (notify.ts) ---
AFY_NOTIFY_COOLDOWN_MS=900000   # min ms between pushes (default 15m)
AFY_NOTIFY_TOP_N=5

# Poke fallback channel (only used if AFY_IMESSAGE_TO is unset).
POKE_API_KEY=
POKE_URL=https://poke.com/api/v1/inbound/api-message

# --- Storage ---
AFY_DB=afy.db
