{
  "name": "afy-ingest",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env.local --experimental-strip-types server.ts",
    "test": "node --experimental-strip-types --test server.test.ts m5m6.test.ts digest.test.ts rubric.test.ts funnel.test.ts interleave.test.ts scorecard.test.ts recall.test.ts",
    "funnel": "node --experimental-strip-types funnel.ts",
    "interleave": "node --experimental-strip-types interleave.ts",
    "scorecard": "node --experimental-strip-types scorecard.ts",
    "recall": "node --experimental-strip-types recall.ts",
    "preeval": "node --env-file-if-exists=.env.local --experimental-strip-types rubric.ts --reviews-only || true",
    "eval": "node --experimental-strip-types eval.ts",
    "probe": "node --experimental-strip-types probe.ts",
    "labels": "node --experimental-strip-types labels.ts",
    "digest": "node --experimental-strip-types digest.ts",
    "rubric": "node --env-file-if-exists=.env.local --experimental-strip-types rubric.ts",
    "daily": "node --env-file-if-exists=.env.local --experimental-strip-types daily.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
